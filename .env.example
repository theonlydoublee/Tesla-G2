# Copy to .env.local (or export before build). Vite only exposes vars prefixed with VITE_.

# When the UI is static-only (e.g. Even Hub .ehpk on the phone), set this to your deployed
# Node server origin (no path, no trailing slash). All /api/tesla/* calls go there.
# VITE_API_BASE_URL=https://even.thedevcave.xyz

# Optional: packed plugin redirects WebView here (defaults to VITE_API_BASE_URL). Requires VITE_REDIRECT_TO_HOSTED.
# VITE_HOSTED_APP_ORIGIN=https://even.thedevcave.xyz

# Set to true only if you want full-page redirect to hosted URL (often breaks glasses bridge)
# VITE_REDIRECT_TO_HOSTED=true

# Optional: public Tesla OAuth client id so sign-in works even if /api/tesla/config fails
# VITE_TESLA_CLIENT_ID=your_tesla_client_id
