# Used only by `vite build`. Never put Tesla client secrets here — use Server/.env for the API.
VITE_API_BASE_URL=https://even.thedevcave.xyz

# Where the packed plugin should send the browser (default: same as VITE_API_BASE_URL if unset)
# VITE_HOSTED_APP_ORIGIN=https://even.thedevcave.xyz

# Optional: public OAuth client id (same as server TESLA_CLIENT_ID)
# VITE_TESLA_CLIENT_ID=
