# Tesla Developer Portal credentials
TESLA_CLIENT_ID=your_tesla_client_id
TESLA_CLIENT_SECRET=your_tesla_client_secret

# OAuth redirect URI (must match Tesla Developer Portal)
TESLA_REDIRECT_URI=https://even.thedevcave.xyz/auth/callback

# CORS allowed origin (your app's origin)
ALLOWED_ORIGIN=https://even.thedevcave.xyz

# Server port (default: 3000)
PORT=3000
