# Tesla Developer Portal credentials
TESLA_CLIENT_ID=your_tesla_client_id
TESLA_CLIENT_SECRET=your_tesla_client_secret

# OAuth code exchange uses audience https://fleet-api.prd.na.vn.cloud.tesla.com (see server FLEET_AUDIENCE).
# Each session’s Fleet API host is resolved via GET /api/1/users/region (NA/EU). China is not enabled here.

# OAuth redirect URI (must match Tesla Developer Portal)
TESLA_REDIRECT_URI=https://even.thedevcave.xyz/auth/callback

# CORS: single origin, or * to allow any Origin (needed if Even Hub sends varying origins)
ALLOWED_ORIGIN=https://even.thedevcave.xyz

# Optional: comma-separated extra origins. Use * alone in ALLOWED_ORIGIN for dev/wide open CORS.
# ALLOWED_ORIGINS=http://192.168.1.10:8080,https://hub.example.com

# Server port (default: 3000)
PORT=3000

# SQLite file for Tesla OAuth sessions (refresh + access tokens). Default: Server/tesla-sessions.sqlite
# TESLA_SESSIONS_DB=/data/tesla-sessions.sqlite
